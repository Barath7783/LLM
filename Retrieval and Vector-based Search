from langchain_core.documents import Document
from langchain_text_splitters import RecursiveCharacterTextSplitter
from langchain_community.embeddings import HuggingFaceEmbeddings
from langchain_community.vectorstores import FAISS

docs = [Document(page_content=t) for t in [
    "AI enables machines to think.",
    "Machine learning is part of AI.",
    "Deep learning uses neural networks."
]]

docs = RecursiveCharacterTextSplitter(chunk_size=40, chunk_overlap=10).split_documents(docs)

db = FAISS.from_documents(docs, HuggingFaceEmbeddings(model_name="sentence-transformers/all-MiniLM-L6-v2"))

while True:
    q = input("Query: ")
    if q == "exit": break
    for d in db.as_retriever(k=2).invoke(q):
        print("-", d.page_content)
